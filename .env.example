NODE_ENV=development

APP_NAME=LiveU Secure File Transfer
APP_PUBLIC_URL=http://localhost
APP_INTERNAL_URL=http://web:3000
APP_PORT=3000
WORKER_PORT=3100
SESSION_TTL_HOURS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

DATABASE_URL=postgresql://liveu:liveu@db:5432/liveu_secure_file_transfer?schema=public
DIRECT_URL=postgresql://liveu:liveu@db:5432/liveu_secure_file_transfer?schema=public

SESSION_SECRET=change-me-with-64-random-characters
CSRF_SECRET=change-me-with-64-random-characters

DEFAULT_ADMIN_EMAIL=admin@liveu.local
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=LiveU Secure File Transfer <no-reply@liveu.local>

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=liveu-secure-transfers
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_CONSOLE_PORT=9001

POSTGRES_DB=liveu_secure_file_transfer
POSTGRES_USER=liveu
POSTGRES_PASSWORD=liveu

CADDY_SITE_ADDRESS=localhost
LETSENCRYPT_EMAIL=infra@example.com
